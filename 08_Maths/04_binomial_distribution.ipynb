     "output_type": "stream",
     "text": [
      "The probability of getting exactly 3 successes in 5 trials with success probability 0.5 is: 0.3125\n"
     ]
    }
   ],
   "source": [
    "from scipy.stats import binom\n",
    "n=5\n",
    "k=3\n",
    "p=0.5   \n",
    "prob = binom.pmf(k, n, p)\n",
    "print(f\"The probability of getting exactly {k} successes in {n} trials with success probability {p} is: {prob:.4f}\")"
   ]
  }
 ],
